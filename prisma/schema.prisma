// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  password        String
  name            String?
  memories        Memory[]
  yearSummaries   YearSummary[]
  // 密闭阁楼二次密码（可选）
  vaultPasswordHash String?
  vaultSalt          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Memory {
  id        String   @id @default(cuid())
  title     String
  content   String?
  date      DateTime
  imageUrl  String?
  location  String?
  // 密闭阁楼相关
  isPrivate Boolean  @default(false) // 是否仅阁楼可见
  encrypted Boolean  @default(false) // 是否经过内容加密
  ciphertext String?                 // 加密后的密文（Base64）
  iv         String?                 // AES-GCM 向量（Base64）
  salt       String?                 // KDF 盐（Base64，用于从阁楼密码导出密钥）

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YearSummary {
  id         String   @id @default(cuid())
  year       String
  title      String
  summary    String
  highlight1 String?
  highlight2 String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, year])
}
