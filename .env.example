# ========== 本地开发：从 Vercel Environment Variables 复制到 .env.local ==========
# 云上有 DIRECT_DATABASE_URL / JWT_SECRET / POSTGRES_URL / DATABASE_URL / PRISMA_DATABASE_URL
# 本项目实际用到的如下，其余不用配。

# 【必填】Prisma 连接库
DATABASE_URL="postgresql://..."
DIRECT_DATABASE_URL="postgresql://..."

# 【可选】登录会话签名。不填则本地用默认密钥；填上与云一致更稳妥
# JWT_SECRET="..."

# 【可选】AI 诗意引言：OpenAI 兼容 API（国内可用 DeepSeek / Moonshot）
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.deepseek.com"   # DeepSeek 必填；OpenAI 官方不填
# AI_POETIC_MODEL="deepseek-chat"              # DeepSeek 用此；OpenAI 可不填（默认 gpt-4o-mini）
